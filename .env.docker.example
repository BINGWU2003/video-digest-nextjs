# Shared
REDIS_URL=redis://redis:6379
WEB_APP_URL=http://localhost:3000

# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_xxx
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SERVICE_ROLE_KEY=sb_secret_xxx

# Resend
RESEND_API_KEY=re_xxx
RESEND_FROM_EMAIL=Video Digest <digest@example.com>
RESEND_WEBHOOK_SECRET=whsec_xxx

# Worker video extraction
YTDLP_PATH=yt-dlp

# OpenAI-compatible summary provider
OPENAI_BASE_URL=https://api.deepseek.com
OPENAI_API_KEY=sk_xxx
OPENAI_SUMMARY_MODEL=deepseek-v4-flash
OPENAI_SUMMARY_MAX_TOKENS=4000

# Local ASR fallback in worker
FASTER_WHISPER_PYTHON_PATH=python3
FASTER_WHISPER_SCRIPT_PATH=/app/scripts/asr/faster-whisper-transcribe.py
FASTER_WHISPER_MODEL=small
FASTER_WHISPER_DEVICE=cpu
FASTER_WHISPER_COMPUTE_TYPE=int8
FASTER_WHISPER_LANGUAGE=zh
FASTER_WHISPER_VAD_FILTER=true
