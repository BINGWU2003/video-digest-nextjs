NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_xxx
SUPABASE_SERVICE_ROLE_KEY=sb_secret_xxx

# Resend Webhook 签名密钥。在 Resend Webhooks 页面创建 endpoint 后复制。
# Endpoint URL: https://your-domain.com/api/webhooks/resend
RESEND_WEBHOOK_SECRET=whsec_xxx

# 邮箱验证邮件由 Web 服务发送，发件地址必须来自 Resend 已验证域名。
RESEND_API_KEY=re_xxx
RESEND_FROM_EMAIL="Video Digest <digest@example.com>"

# 可选。配置后验证邮件会使用这个地址生成点击链接；不配置时使用当前请求 origin。
WEB_APP_URL=http://localhost:3000

# 配置后 `/api/mcp` 会把视频摘要任务真实投递到 BullMQ。
# 未配置时会使用 no-op 队列，仅打通创建链路，不写入 Redis。
REDIS_URL=redis://localhost:6379

# LLM API key 不要放在 Web 端环境变量里。
# 摘要生成由 worker 执行，请配置 apps/worker/.env.local。

# 如果你的项目还在使用旧版 anon key，也可以使用：
# NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...
