REDIS_URL=redis://localhost:6379
SUPABASE_URL=https://your-project-ref.supabase.co

# 本地开发访问 YouTube 等站点时可选；生产环境不要配置。
# 如果你的代理端口是 V2Ray HTTP 代理端口：
LOCAL_PROXY_URL=http://127.0.0.1:10808

# 可选。默认使用 PATH 中的 yt-dlp；生产 Docker 镜像可设为 /usr/local/bin/yt-dlp。
YTDLP_PATH=yt-dlp

# 摘要生成在后台 worker 中执行。DeepSeek 是推荐的 OpenAI-compatible 配置。
# 只做字幕提取时可以不配置；summary / summary_and_email 模式需要配置。
DEEPSEEK_API_KEY=sk_xxx
DEEPSEEK_SUMMARY_MODEL=deepseek-v4-flash

# 如果改用其他 OpenAI-compatible 服务，可以使用下面这组通用变量。
# OPENAI_BASE_URL=https://api.deepseek.com
# OPENAI_API_KEY=sk_xxx
# OPENAI_SUMMARY_MODEL=deepseek-v4-flash
# OPENAI_SUMMARY_MAX_TOKENS=4000

# 仅用于后台 worker，不能暴露到浏览器。
SUPABASE_SERVICE_ROLE_KEY=sb_secret_xxx
