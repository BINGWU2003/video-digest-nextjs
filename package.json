{
  "name": "video-digest-nextjs",
  "private": true,
  "scripts": {
    "build": "turbo run build",
    "check:local": "node scripts/check-local-dev.mjs",
    "dev": "turbo run dev",
    "test": "turbo run test",
    "lint": "turbo run lint",
    "format": "prettier --write \"**/*.{ts,tsx,md}\"",
    "check-types": "turbo run check-types",
    "mcp:build": "pnpm --filter @video-digest-nextjs/mcp-server build",
    "mcp:check": "pnpm --filter @video-digest-nextjs/mcp-server check-types && pnpm --filter @video-digest-nextjs/mcp-server lint && pnpm --filter @video-digest-nextjs/mcp-server build",
    "mcp:pack": "npm pack ./packages/mcp-server --dry-run",
    "mcp:publish": "npm publish ./packages/mcp-server --access public",
    "mcp:version:patch": "npm --prefix packages/mcp-server version patch --no-git-tag-version"
  },
  "devDependencies": {
    "prettier": "catalog:",
    "turbo": "catalog:",
    "typescript": "catalog:"
  },
  "packageManager": "pnpm@9.15.9",
  "engines": {
    "node": ">=18"
  }
}
